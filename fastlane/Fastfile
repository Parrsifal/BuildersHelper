default_platform(:ios)

platform :ios do

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    key_path = File.join(ENV["CM_BUILD_DIR"] || Dir.pwd, "fastlane", "keys", "AuthKey_HFK62GK33W.p8")

    UI.message("Loading API key from: #{key_path}")

    unless File.exist?(key_path)
      UI.user_error!("API key file not found at #{key_path}. Please add your AuthKey_HFK62GK33W.p8 to fastlane/keys/")
    end

    api_key = app_store_connect_api_key(
      key_id: "HFK62GK33W",
      issuer_id: "8daddef0-efc9-4ce6-aaa3-451c4566444a",
      key_filepath: key_path,
      in_house: false
    )

    UI.success("API key loaded successfully!")

    deliver(
      api_key: api_key,
      app_identifier: "com.buildershelper",
      metadata_path: "./BuildersMeta",
      screenshots_path: "./screenshots",
      skip_binary_upload: true,
      skip_app_version_update: true,
      skip_screenshots: true,
      skip_metadata: true,
      force: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

end
