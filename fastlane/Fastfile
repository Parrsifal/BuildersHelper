default_platform(:ios)

platform :ios do

  desc "Upload metadata and screenshots to App Store Connect"
  lane :upload_metadata do
    # Use the API key from Codemagic's App Store Connect integration (env var)
    key_content = ENV["APP_STORE_CONNECT_PRIVATE_KEY"]

    if key_content.nil? || key_content.empty?
      UI.user_error!("APP_STORE_CONNECT_PRIVATE_KEY env var not set. Make sure the App Store Connect integration is configured in Codemagic.")
    end

    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_IDENTIFIER"] || "QU8A7362L5",
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"] || "8daddef0-efc9-4ce6-aaa3-451c4566444a",
      key_content: key_content,
      in_house: false
    )

    UI.success("API key loaded successfully!")

    deliver(
      api_key: api_key,
      app_identifier: "com.buildershelper",
      metadata_path: "./BuildersMeta",
      screenshots_path: "./screenshots",
      skip_binary_upload: true,
      skip_app_version_update: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      overwrite_screenshots: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      run_precheck_before_submit: false
    )
  end

end
